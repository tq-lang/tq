#!/usr/bin/env bash
set -euo pipefail

MSG_FILE="${1:-}"
if [[ -z "$MSG_FILE" || ! -f "$MSG_FILE" ]]; then
  echo "tq: commit-msg hook requires a commit message file path" >&2
  exit 1
fi

FIRST_LINE="$(sed -n '1p' "$MSG_FILE" | sed 's/[[:space:]]*$//')"

# Allow common git-generated messages and autosquash prefixes.
if [[ "$FIRST_LINE" =~ ^(Merge|Revert\ \"|fixup!\ |squash!\ ) ]]; then
  exit 0
fi

if [[ "$FIRST_LINE" =~ ^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?(!)?:\ .+ ]]; then
  exit 0
fi

cat >&2 <<'EOF'
tq: invalid commit message format.
Use Conventional Commits:
  <type>(optional-scope): <description>

Examples:
  feat(cli): add --stream-threshold flag
  fix: handle empty stdin gracefully
EOF
exit 1
